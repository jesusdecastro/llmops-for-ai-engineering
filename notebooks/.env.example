# ============================================
# LLMOps Course - Environment Variables
# ============================================
# Copia este archivo a .env y rellena con tus valores:
#   cp .env.example .env
# ============================================

# --- AWS Bedrock ---
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1

# Modelo de Bedrock (puedes cambiarlo)
MODEL_ID=us.anthropic.claude-sonnet-4-20250514

# --- Langfuse Cloud ---
# Crea tu cuenta gratuita en https://cloud.langfuse.com
# Luego: Settings > API Keys > Create API Key
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
