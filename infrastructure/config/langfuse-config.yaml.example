# Configuración Langfuse (alineada con ConfigValidator)
# Copiar a langfuse-config.yaml y personalizar

langfuse:
  version: "3"
  port: 3000

  init:
    admin_email: admin@curso-llmops.local
    admin_name: Admin Curso
    org_id: org-curso-llmops
    org_name: Curso LLMOps
    project_id: proj-techshop-agent
    project_name: techshop-agent
    project_public_key: pk-lf-techshop

  postgres:
    database: langfuse
    user: langfuse
    port: 5432

  clickhouse:
    database: langfuse
    user: langfuse
    http_port: 8123
    native_port: 9000

  redis:
    port: 6379

  minio:
    root_user: langfuse
    bucket: langfuse
    port: 9000
    console_port: 9001

  resources:
    web:
      memory: 2Gi
    worker:
      memory: 2Gi
    postgres:
      memory: 4Gi
    clickhouse:
      memory: 4Gi
    redis:
      memory: 1Gi
    minio:
      memory: 1Gi

  security:
    session_timeout_minutes: 480
