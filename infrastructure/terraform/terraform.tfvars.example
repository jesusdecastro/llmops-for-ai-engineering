aws_profile = "default"
aws_region  = "us-east-1"

project_name = "langfuse-workshop"
environment  = "training"
owner_email  = "instructor@example.com"

instance_type = "t3.xlarge"
volume_size   = 100

vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

ssh_allowed_cidrs = [
  "203.0.113.0/24",
]

langfuse_allowed_cidrs = [
  "0.0.0.0/0",
]

enable_https  = false
langfuse_port = 3000

alert_email        = "instructor@example.com"
enable_cloudwatch  = true
log_retention_days = 7

parameter_prefix             = "/langfuse/workshop"
ssh_private_key_output_path  = "../generated/langfuse-workshop.pem"

tags = {
  Project     = "LLMOps-Workshop"
  Environment = "Training"
  ManagedBy   = "Terraform"
  CostCenter  = "Training"
}